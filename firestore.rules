rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required, immutable)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: users/{userId}/history
    // Document ID: {historyId}
    // Fields:
    //   - uid: string (required, immutable)
    //   - formData: map (required)
    //   - generatedPrompt: string (required)
    //   - generatedImage: string (optional)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.createdAt is timestamp &&
             (!('displayName' in data) || data.displayName is string);
    }

    function isValidHistory(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.formData is map &&
             data.generatedPrompt is string && data.generatedPrompt.size() > 0 && data.generatedPrompt.size() < 10000 &&
             (!('generatedImage' in data) || (data.generatedImage is string && data.generatedImage.size() < 1048576)) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && 
                    hasRequiredFields(['uid', 'email', 'createdAt']) &&
                    isValidUser(request.resource.data) &&
                    uidUnchanged();
      allow update: if isOwner(userId) && 
                    isDocOwner() &&
                    isValidUser(request.resource.data) &&
                    uidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(userId) && isDocOwner();

      match /history/{historyId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) &&
                      hasRequiredFields(['uid', 'formData', 'generatedPrompt', 'createdAt']) &&
                      isValidHistory(request.resource.data) &&
                      uidUnchanged();
        allow update: if isOwner(userId) &&
                      isDocOwner() &&
                      isValidHistory(request.resource.data) &&
                      uidNotModified() &&
                      request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(userId) && isDocOwner();
      }
    }
  }
}
